// ─────────────────────────────────────────────────────────
// UniClubs — Prisma Schema
// ─────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════

enum UserRole {
  USER
  SUPER_ADMIN
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum EventType {
  PUBLIC
  PRIVATE
}

enum LocationType {
  ONLINE
  PHYSICAL
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  EVENT_PUBLISHED
  EVENT_CANCELLED
  GENERAL
}

// ═══════════════════════════════════════════════════════════
// USERS
// ═══════════════════════════════════════════════════════════

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  password            String
  firstName           String    @map("first_name")
  lastName            String    @map("last_name")
  avatarUrl           String?   @map("avatar_url")
  role                UserRole  @default(USER)
  isOrganizer         Boolean   @default(false) @map("is_organizer") // can create events and manage join requests
  onboardingCompleted Boolean   @default(false) @map("onboarding_completed")
  isBanned            Boolean   @default(false) @map("is_banned")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  // Relations
  interests     UserInterest[]
  events        Event[]          @relation("EventOrganizer")
  bookings      Booking[]
  notifications Notification[]

  @@index([email])
  @@index([role])
  @@map("users")
}

// ═══════════════════════════════════════════════════════════
// INTERESTS / TAGS
// ═══════════════════════════════════════════════════════════

model Interest {
  id        String   @id @default(uuid())
  name      String   @unique              // e.g. "sports", "music", "tech"
  createdAt DateTime @default(now()) @map("created_at")

  users UserInterest[]

  @@map("interests")
}

model UserInterest {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  interestId String   @map("interest_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  interest Interest @relation(fields: [interestId], references: [id], onDelete: Cascade)

  @@unique([userId, interestId])
  @@index([userId])
  @@map("user_interests")
}

// ═══════════════════════════════════════════════════════════
// EVENTS
// ═══════════════════════════════════════════════════════════

model Event {
  id                String       @id @default(uuid())
  title             String
  description       String?
  type              EventType    @default(PUBLIC)
  startTime         DateTime     @map("start_time")
  endTime           DateTime?    @map("end_time")
  locationType      LocationType @default(PHYSICAL) @map("location_type")
  location          String?
  status            EventStatus  @default(DRAFT)
  capacity          Int?
  remainingCapacity Int?         @map("remaining_capacity")  // denormalized for perf
  organizerId       String       @map("organizer_id")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  // Relations
  organizer User       @relation("EventOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  bookings  Booking[]
  tags      EventTag[]

  @@index([organizerId])
  @@index([status])
  @@index([startTime])
  @@map("events")
}

model EventTag {
  id      String @id @default(uuid())
  eventId String @map("event_id")
  tag     String

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, tag])
  @@index([tag])
  @@map("event_tags")
}

// ═══════════════════════════════════════════════════════════
// BOOKINGS  (join requests — organizer can CONFIRM or CANCEL)
// ═══════════════════════════════════════════════════════════

model Booking {
  id        String        @id @default(uuid())
  eventId   String        @map("event_id")
  userId    String        @map("user_id")
  status    BookingStatus @default(PENDING)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@map("bookings")
}

// ═══════════════════════════════════════════════════════════
// NOTIFICATIONS
// ═══════════════════════════════════════════════════════════

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String
  metadata  Json?            @db.JsonB        // arbitrary payload
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ═══════════════════════════════════════════════════════════
// CHAT MESSAGES (for event chat) (youssef)
// ═══════════════════════════════════════════════════════════
model EventChatMessage {
  id          String   @id @default(uuid())
  eventId     String   @map("event_id")
  userId      String   @map("user_id")
  username    String
  content     String
  isModerated Boolean  @default(false) @map("is_moderated")
  createdAt   DateTime @default(now()) @map("created_at")
  
  // Relations
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
  @@index([userId])
  @@map("event_chat_messages")
}