# ── App ───────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────
POSTGRES_DB=uniclubs
POSTGRES_USER=uniclubs
POSTGRES_PASSWORD=uniclubs_secret
DATABASE_URL=postgresql://uniclubs:uniclubs_secret@postgres:5432/uniclubs?schema=public

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-long-random
JWT_REFRESH_EXPIRY=7d

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
