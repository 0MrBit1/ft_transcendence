# ── App ───────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────
POSTGRES_DB=uniclubs
POSTGRES_USER=uniclubs
POSTGRES_PASSWORD=<your-strong-password-here>
DATABASE_URL=postgresql://uniclubs:<your-strong-password-here>@postgres:5432/uniclubs?schema=public

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=<generate-a-64-char-random-string>
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=<generate-another-64-char-random-string>
JWT_REFRESH_EXPIRY=7d

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Seeding ───────────────────────────────────────────────
# Set to "true" to run seed on container startup, "false" to skip
RUN_SEED=true
